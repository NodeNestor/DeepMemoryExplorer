# Deep Memory Explorer configuration

# HiveMindDB connection
HIVEMIND_URL=http://localhost:8100

# LLM provider — any OpenAI-compatible endpoint works:
#   CodeGate:  http://localhost:8989/v1    (default — local AI gateway)
#   vLLM:      http://localhost:8000/v1
#   Ollama:    http://localhost:11434/v1
#   OpenAI:    https://api.openai.com/v1
LLM_API_URL=http://localhost:8989/v1
LLM_MODEL=Qwen/Qwen3.5-0.8B
LLM_API_KEY=
LLM_MAX_TOKENS=16384

# App settings
APP_PORT=3000
AGENT_MAX_ITERATIONS=10
